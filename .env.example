NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-07-11
# Write token — used ONLY by scripts/migrate-sanity.ts, not by the running app.
SANITY_API_TOKEN=sk_your_write_token
SANITY_READ_TOKEN=sk_your_viewer_token
# SMTP login for the underlying iCloud mailbox.
ICLOUD_SMTP_USER=your-icloud-mailbox@icloud.com
ICLOUD_SMTP_PASS=your_app_specific_password
# Verified custom-domain sender and inbox.
CONTACT_EMAIL=info@floraohio.com
# Set to stub for local development only.
CONTACT_DELIVERY_MODE=
NEXT_PUBLIC_SITE_URL=https://floraohio.com
# Set to "true" in production to enable the cookie consent banner.
# Vercel Analytics and Speed Insights are gated by the "analytics" consent category.
# When false, analytics load unconditionally.
NEXT_PUBLIC_ENABLE_COOKIE_CONSENT=false
# Content runtime behavior (local | preview | production | e2e).
# Defaults to "local" in dev, "production" on Vercel production deploys.
CONTENT_RUNTIME_MODE=
# Set to "true" to enable the custom cursor (default: disabled).
NEXT_PUBLIC_ENABLE_CUSTOM_CURSOR=false
